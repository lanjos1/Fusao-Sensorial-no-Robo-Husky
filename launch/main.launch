<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="mode" default="odom" doc="odom, odom_imu ou odom_imu_gps"/>
  <arg name="bag" default="$(find localizacao_husky)/bags/sensores_husky.bag"/>
  <arg name="rate" default="2.0"/>
  <arg name="output_dir" default="$(find localizacao_husky)/results"/>
  <arg name="gt_offset_x" default="0.0"/>
  <arg name="gt_offset_y" default="0.0"/>

  <param name="/use_sim_time" value="false"/>

  <node pkg="topic_tools" type="relay" name="relay_bag_wheel" args="/husky_velocity_controller/odom /wheel/odom"/>
  
  <node pkg="topic_tools" type="relay" name="relay_bag_gt" args="/gazebo_ground_truth/odom /gt/odom"/>

  <include file="$(find localizacao_husky)/launch/configs.launch">
    <arg name="mode"             value="$(arg mode)"/>
    <arg name="wheel_odom_topic" value="/wheel/odom"/>
    <arg name="imu_topic"        value="/imu/data"/>
    <arg name="fix_topic"        value="/navsat/fix"/>
    <arg name="publish_gt"       value="false"/> <arg name="record_metrics"   value="true"/>
    <arg name="output_dir"       value="$(arg output_dir)"/>
    <arg name="gt_offset_x"      value="$(arg gt_offset_x)"/>
    <arg name="gt_offset_y"      value="$(arg gt_offset_y)"/>
  </include>

  <node pkg="rosbag" type="play" name="play_trajectory" output="screen" required="true"
        args="--delay=2.0 --rate=$(arg rate) $(arg bag)"/>
</launch>